# Configuracion del agente ganadero
# Copia este archivo a .env y completa los valores reales

# API key de Google AI Studio (obligatoria)
# Obtenla en: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Modelo de Gemini a utilizar (opcional)
MODEL_NAME=gemini-2.0-flash

# Ruta al dataset ganadero (opcional)
DATASET_PATH=data/ganaderia_dataset.csv

# Temperatura del modelo, 0 = determinista (opcional)
TEMPERATURE=0
